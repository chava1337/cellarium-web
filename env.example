# Configuración de Supabase
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Configuración de Google Vision API (para reconocimiento de etiquetas)
EXPO_PUBLIC_GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# Configuración de OpenAI (para generación de fichas)
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here

# Configuración de la aplicación
EXPO_PUBLIC_APP_NAME=Cellarium
EXPO_PUBLIC_APP_VERSION=1.0.0

# Configuración de desarrollo
EXPO_PUBLIC_DEBUG_MODE=true
EXPO_PUBLIC_LOG_LEVEL=debug
