{
  "name": "cellarium-wine-catalog",
  "version": "1.0.0",
  "description": "Sistema de catálogo de vinos para restaurantes con acceso QR",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:all": "eas build --platform all",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "expo r -c",
    "reset": "expo r -c && npm start"
  },
  "keywords": [
    "react-native",
    "expo",
    "wine",
    "catalog",
    "restaurant",
    "qr",
    "inventory",
    "supabase"
  ],
  "author": "Cellarium Team",
  "license": "MIT",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-google-signin/google-signin": "^16.0.0",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@stripe/stripe-react-native": "^0.57.0",
    "@supabase/supabase-js": "^2.38.4",
    "babel-preset-expo": "^54.0.4",
    "expo": "^54.0.13",
    "expo-camera": "~17.0.8",
    "expo-clipboard": "^8.0.7",
    "expo-dev-client": "~6.0.15",
    "expo-file-system": "^19.0.17",
    "expo-font": "~14.0.9",
    "expo-image": "^3.0.10",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.8",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "^8.0.8",
    "expo-print": "~15.0.7",
    "expo-screen-orientation": "~9.0.7",
    "expo-secure-store": "~15.0.7",
    "expo-sharing": "^14.0.7",
    "expo-status-bar": "~3.0.8",
    "expo-web-browser": "^15.0.8",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-html-to-pdf": "^1.3.0",
    "react-native-qrcode-svg": "^6.3.15",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-share": "^12.2.1",
    "react-native-svg": "^15.14.0",
    "react-native-vision-camera": "^4.7.2",
    "react-native-worklets": "^0.6.1",
    "react-native-worklets-core": "^1.6.2",
    "rive-react-native": "^9.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.2.1",
    "prettier": "^3.1.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  },
  "private": true
}
